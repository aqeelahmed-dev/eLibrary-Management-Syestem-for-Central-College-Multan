# ============================================================
#  Supabase — paste your 3 values from
#  Supabase Dashboard → Project Settings → API
# ============================================================

# Project URL  (looks like https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key  (long eyJ... string — safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key  (long eyJ... string — SECRET, server-only, never expose)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Connect → Session pooler) — used only by scripts/migrate.mjs
DATABASE_URL=
